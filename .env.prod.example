# Production (.env.prod) — API on this host; frontend on Vercel.
#
# Cloudflare tunnel hostname for the API:
#   https://sop-opera-api.aahil-khan.tech  →  localhost:8000
#
# Set CORS_ORIGINS to your Vercel URL(s), e.g.:
#   https://sop-opera.aahil-khan.tech,https://sop-opera.vercel.app

# --- Postgres (db service) ---
POSTGRES_USER=sop
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=sop_opera

# --- Published API port on the host ---
API_PORT=8000

# --- Backend ---
# DATABASE_URL is set in docker-compose.prod.yml (points at db:5432).
CORS_ORIGINS=https://sop-opera.aahil-khan.tech,https://sop-opera.vercel.app
CORS_LOCALHOST_REGEX=

# AI providers: mock | openai_compatible | ollama
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

ASSESSMENT_MAX_RETRIES=1
ASSESSMENT_WORKER_COUNT=2
ASSESSMENT_LEASE_SECONDS=300

GAS_ELEVATED_THRESHOLD=20.0
GAS_CRITICAL_THRESHOLD=50.0
TEMP_ELEVATED_THRESHOLD=80.0
TEMP_CRITICAL_THRESHOLD=120.0
VIBRATION_ANOMALY_THRESHOLD=7.1
EFFLUENT_PH_MIN=6.0
EFFLUENT_PH_MAX=9.0
TANK_LEVEL_HIGH_PCT=95.0
TANK_LEVEL_LOW_PCT=5.0
WEATHER_WIND_HOLD_MS=15.0
CERT_EXPIRY_WARNING_DAYS=14

SIMULATOR_DEFAULT_STEP_DELAY_SECONDS=5
BLOCKED_INACTIVE_MIN_SECONDS=15
BLOCKED_INACTIVE_MAX_SECONDS=60

RAG_ENABLED=true
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.72
RAG_TIMEOUT_MS=3000

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=sop-opera
LANGSMITH_PROJECT_URL=
AGENT_SPATIAL_RADIUS_M=15.0
AGENT_SCALE_M_PER_PX=0.04
AGENT_TIMEOUT_SECONDS=45
AGENT_LLM_TIMEOUT_SECONDS=20
PREDICTIVE_TREND_HORIZON_MINUTES=15.0
PREDICTIVE_TREND_MIN_R2=0.55
PREDICTIVE_TREND_MIN_SAMPLES=2

AMBIENT_ENABLED=true
AMBIENT_TICK_SECONDS=3.0
AMBIENT_COINCIDENCE_PROBABILITY=0.01
AMBIENT_HEARTBEAT_SECONDS=120
AMBIENT_BATCH_SIZE=2
AMBIENT_STATUS_EVERY_N_TICKS=4
