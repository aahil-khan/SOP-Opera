# Backend
DATABASE_URL=postgresql+asyncpg://sop:sop@localhost:5433/sop_opera
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Optional: regex for local dev when Next.js picks another port (empty to disable)
# CORS_LOCALHOST_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

# AI providers: mock | openai_compatible | ollama
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Assessment
ASSESSMENT_MAX_RETRIES=1

# Sensor & rule thresholds (backend source of truth — UI reads GET /api/config/thresholds)
# Elevated = compound-engine early warning; critical = single-sensor incident line.
# Critical must stay above elevated for gas/temp.
GAS_ELEVATED_THRESHOLD=20.0
GAS_CRITICAL_THRESHOLD=50.0
TEMP_ELEVATED_THRESHOLD=80.0
TEMP_CRITICAL_THRESHOLD=120.0
VIBRATION_ANOMALY_THRESHOLD=7.1
EFFLUENT_PH_MIN=6.0
EFFLUENT_PH_MAX=9.0
TANK_LEVEL_HIGH_PCT=95.0
TANK_LEVEL_LOW_PCT=5.0
WEATHER_WIND_HOLD_MS=15.0
CERT_EXPIRY_WARNING_DAYS=14

# Simulator
SIMULATOR_DEFAULT_STEP_DELAY_SECONDS=5
BLOCKED_INACTIVE_MIN_SECONDS=15
BLOCKED_INACTIVE_MAX_SECONDS=60

# RAG / embeddings
RAG_ENABLED=true
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.72
RAG_TIMEOUT_MS=3000

# LangGraph multi-agent + LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=sop-opera
# Optional override for the Open LangSmith button (defaults to https://smith.langchain.com)
LANGSMITH_PROJECT_URL=
AGENT_SPATIAL_RADIUS_M=15.0
AGENT_SCALE_M_PER_PX=0.04
AGENT_TIMEOUT_SECONDS=45
AGENT_LLM_TIMEOUT_SECONDS=20
PREDICTIVE_TREND_HORIZON_MINUTES=15.0
PREDICTIVE_TREND_MIN_R2=0.55
PREDICTIVE_TREND_MIN_SAMPLES=2

# Always-on ambient plant telemetry (soft gauges + rare coincidence failures)
AMBIENT_ENABLED=true
AMBIENT_TICK_SECONDS=3.0
AMBIENT_COINCIDENCE_PROBABILITY=0.01
AMBIENT_HEARTBEAT_SECONDS=120
AMBIENT_BATCH_SIZE=2
AMBIENT_STATUS_EVERY_N_TICKS=4

# Frontend (Next.js) — copy relevant into frontend/.env.local
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
