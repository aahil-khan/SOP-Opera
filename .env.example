# Backend
DATABASE_URL=postgresql+asyncpg://sop:sop@localhost:5433/sop_opera
CORS_ORIGINS=http://localhost:3000

# AI providers: mock | openai_compatible | ollama
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Assessment
ASSESSMENT_MAX_RETRIES=1
GAS_ELEVATED_THRESHOLD=20.0

# Simulator
SIMULATOR_DEFAULT_STEP_DELAY_SECONDS=5

# RAG / embeddings
RAG_ENABLED=true
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.72
RAG_TIMEOUT_MS=3000

# Frontend (Next.js) — copy relevant into frontend/.env.local
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
